# Public production URL. Optional locally; used for sitemap and robots metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Future Supabase integration. The current demo does not require these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only. Never expose this with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
